layout {

    pane size=1 borderless=true {
        plugin location="zellij:tab-bar"
    }

    // Tab 1: Molt.tui workspace
    tab name="Molt.tui" focus=true {
        pane split_direction="vertical" {
            // Molt.tui runs in the left pane
            pane command="bun" size="40%" {
                args "run" "start"
                cwd "/mnt/d/moltui"
                name "molt.tui"
            }
            // Right side: two stacked shells
            pane split_direction="horizontal" {
                pane name="work"
                pane name="logs"
            }
        }
    }

    // Tab 2: Dev shells
    tab name="Dev" {
        pane split_direction="vertical" {
            pane
            pane
            pane
        }
    }

    pane size=1 borderless=true {
        plugin location="zellij:status-bar"
    }

}
